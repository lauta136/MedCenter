@model IEnumerable<MedCenter.DTOs.MedicoViewDTO>
@{
    ViewData["Title"] = "Reportes";
    Layout = "~/Views/Shared/_SecretariaLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
         <!-- Client-side error container -->
        <div id="clientErrorMessage" class="alert alert-danger alert-dismissible fade show" role="alert" style="display: none;">
            <i class="fas fa-exclamation-circle me-2"></i>
            <span id="clientErrorText"></span>
            <button type="button" class="btn-close" onclick="clearClientError()"></button>
        </div>

        <!-- Estadísticas del mes -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="fas fa-chart-line me-2 text-success"></i>
                    Estadísticas del Mes
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <div class="stat-card">
                            <div class="stat-icon bg-primary">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                            <div class="stat-content">
                                <h3 class="stat-number">@ViewBag.TurnosMes</h3>
                                <p class="stat-label">Turnos del Mes</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="stat-card">
                            <div class="stat-icon bg-success">
                                <i class="fas fa-user-plus"></i>
                            </div>
                            <div class="stat-content">
                                <h3 class="stat-number">@ViewBag.PacientesNuevosMes</h3>
                                <p class="stat-label">Pacientes Totales</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="stat-card">
                            <div class="stat-icon bg-danger">
                                <i class="fas fa-times-circle"></i>
                            </div>
                            <div class="stat-content">
                                <h3 class="stat-number">@ViewBag.TurnosCancelados</h3>
                                <p class="stat-label">Turnos Cancelados</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Opciones de reportes -->
        <div class="row">
            <!-- DETAILED REPORT (Original - Full data) -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 border-start border-primary border-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-file-alt me-2 text-primary"></i>
                            Reporte Detallado de Turnos
                        </h5>
                        <p class="text-muted">
                            <strong>📋 Listado completo</strong><br>
                            Incluye todos los turnos con información detallada de cada cita más estadísticas agregadas.
                        </p>
                        <form id="formTurnos" class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Desde</label>
                                <input type="date" id="fechaDesde" name="fechaDesde" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fecha Hasta</label>
                                <input type="date" id="fechaHasta" name="fechaHasta" class="form-control" required />
                            </div>
                            <button type="button" onclick="descargarTurnosPDF()" class="btn btn-danger w-100 mb-2">
                                <i class="fas fa-file-pdf me-2"></i>
                                Descargar PDF Detallado
                            </button>
                            <button type="button" onclick="previsualizarTurnosPDF()" class="btn btn-outline-danger w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa PDF
                            </button>
                            <button type="button" onclick="descargarTurnosExcel()" class="btn btn-success w-100">
                                <i class="fas fa-file-excel me-2"></i>
                                Descargar Excel Detallado
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- SUMMARY REPORT (New - Only statistics) -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 border-start border-warning border-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-chart-pie me-2 text-warning"></i>
                            Resumen de Turnos
                        </h5>
                        <p class="text-muted">
                            <strong>📈 Solo totales y estadísticas</strong><br>
                            Vista rápida sin detalle de turnos individuales. Ideal para reportes gerenciales breves.
                        </p>
                        <form id="formResumen" class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Desde</label>
                                <input type="date" id="fechaDesdeResumen" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fecha Hasta</label>
                                <input type="date" id="fechaHastaResumen" class="form-control" required />
                            </div>
                            <button type="button" onclick="descargarResumenPDF()" class="btn btn-warning w-100 mb-2">
                                <i class="fas fa-chart-bar me-2"></i>
                                Descargar Resumen
                            </button>
                            <button type="button" onclick="previsualizarResumenPDF()" class="btn btn-outline-warning w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa Resumen
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- EXECUTIVE REPORT (New - Metrics first) -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 border-start border-info border-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-briefcase me-2 text-info"></i>
                            Reporte Ejecutivo
                        </h5>
                        <p class="text-muted">
                            <strong>📊 Incluye gráficos y KPIs</strong><br>
                            Dashboard gerencial con estadísticas procesadas, insights estratégicos y recomendaciones para toma de decisiones
                        </p>
                        <ul class="small text-muted mb-3">
                            <li>Tasas de asistencia, cancelación y no-show</li>
                            <li>Gráficos de distribución por estado</li>
                            <li>Top performers y especialidades demandadas</li>
                            <li>Recomendaciones basadas en datos</li>
                        </ul>
                        <form id="formEjecutivo" class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Desde</label>
                                <input type="date" id="fechaDesdeEjecutivo" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fecha Hasta</label>
                                <input type="date" id="fechaHastaEjecutivo" class="form-control" required />
                            </div>
                            <button type="button" onclick="descargarEjecutivoPDF()" class="btn btn-info w-100 mb-2 text-white">
                                <i class="fas fa-chart-line me-2"></i>
                                Descargar PDF Ejecutivo
                            </button>
                            <button type="button" onclick="previsualizarEjecutivoPDF()" class="btn btn-outline-info w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa Ejecutivo
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-users me-2 text-success"></i>
                            Reporte de Pacientes
                        </h5>
                        <p class="text-muted">Listado completo de pacientes registrados</p>
                        <div class="mt-3">
                            <button onclick="descargarPacientesPDF()" class="btn btn-danger w-100 mb-2">
                                <i class="fas fa-file-pdf me-2"></i>
                                Descargar Listado PDF
                            </button>
                            <button onclick="previsualizarPacientesPDF()" class="btn btn-outline-danger w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa PDF
                            </button>
                            <button onclick="descargarPacientesExcel()" class="btn btn-success w-100">
                                <i class="fas fa-file-excel me-2"></i>
                                Exportar a Excel
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-filter me-2 text-info"></i>
                            Reporte Filtrado
                        </h5>
                        <p class="text-muted">Filtra turnos por médico y/o especialidad en un período específico</p>
                        <form class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Período <span class="text-danger">*</span></label>
                                <select class="form-select" id="periodo" onchange="onPeriodoChange()"> 
                                    <option value="">Seleccione un período</option>
                                    <option value="1">Último mes</option>
                                    <option value="3">Últimos 3 meses</option>
                                    <option value="12">Último año</option>
                                </select>
                                <small class="text-muted">Primero seleccione el período para cargar los médicos disponibles</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Especialidad</label>
                                <select class="form-select" id="especialidadId" onchange="filtrarMedicosPorEspecialidad()">
                                    <option value="">Todas las especialidades</option>
                                    @foreach (var especialidad in ViewBag.Especialidades)
                                    {
                                        <option value="@especialidad.id">@especialidad.nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Médico (opcional)</label>
                                <select class="form-select" id="medicoId" disabled>
                                    <option value="">Todos los médicos</option>
                                </select>
                            </div>
                            <button type="button" onclick="descargarTurnosPDFPorMedico()" class="btn btn-danger w-100 mb-2">
                                <i class="fas fa-file-pdf me-2"></i>
                                Descargar PDF
                            </button>
                            <button type="button" onclick="previsualizarTurnosPDFPorMedico()" class="btn btn-outline-danger w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa PDF
                            </button>
                            <button type="button" onclick="descargarTurnosExcelPorMedico()" class="btn btn-success w-100">
                                <i class="fas fa-file-excel me-2"></i>
                                Descargar Excel
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-file-alt me-2 text-primary"></i>
                            Reporte de auditoría de turnos
                        </h5>
                        <p class="text-muted">Genera un reporte detallado de la auditoría de turnos</p>
                        <form id="formAuditoriaTurnos" class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Desde</label>
                                <input type="date" id="fechaDesdeAuditTurno" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fecha Hasta</label>
                                <input type="date" id="fechaHastaAuditTurno" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Usuario</label>
                                <select class="form-select" id="usuarioAcciones" onchange="filtrarAccionPorUsuario()">
                                    <option value="">Todos los Usuarios</option>
                                    @foreach (var usuario in ViewBag.usuarios)
                                    {
                                        <option value="@usuario.Id" data-acciones="@string.Join(",", usuario.Acciones)">@usuario.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Acción (opcional)</label>
                                <select class="form-select" id="accionAudit">
                                    <option value="">Todas las acciones</option>
                                    <option value="INSERT">INSERT</option>
                                    <option value="UPDATE">UPDATE</option>
                                    <option value="CANCEL">CANCEL</option>
                                    <option value="FINALIZE">FINALIZE</option>
                                    <option value="NOSHOW">NOSHOW</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Médico (opcional)</label>
                                <select class="form-select" id="medicoIdAudit">
                                    <option value="">Todos los médicos</option>
                                    @foreach (var medico in Model)
                                    {
                                        <option value="@medico.Id">@medico.Nombre</option>
                                    }
                                </select>
                            </div>
                            <button type="button" onclick="descargarAuditoriaTurnosPDF()" class="btn btn-danger w-100 mb-2">
                                <i class="fas fa-file-pdf me-2"></i>
                                Descargar PDF
                            </button>
                            <button type="button" onclick="previsualizarAuditoriaTurnosPDF()" class="btn btn-outline-danger w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa PDF
                            </button>
                            <button type="button" onclick="descargarAuditoriaTurnosExcel()" class="btn btn-success w-100">
                                <i class="fas fa-file-excel me-2"></i>
                                Descargar Excel
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-user-clock me-2 text-success"></i>
                            Reporte de auditoría de login/logout
                        </h5>
                        <p class="text-muted">Seguimiento de sesiones de usuarios del sistema</p>
                        <form id="formAuditoriaLogins" class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Desde</label>
                                <input type="date" id="fechaDesdeAuditLogin" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fecha Hasta</label>
                                <input type="date" id="fechaHastaAuditLogin" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Usuario (opcional)</label>
                                <select class="form-select" id="usuarioNombreLogin">
                                    <option value="">Todos los Usuarios</option>
                                    @foreach (var usuario in ViewBag.usuarios)
                                    {
                                        <option value="@usuario.Nombre">@usuario.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tipo de Logout (opcional)</label>
                                <select class="form-select" id="tipoLogoutLogin">
                                    <option value="">Todos los tipos</option>
                                    <option value="Manual">Manual</option>
                                    <option value="Timeout">Timeout</option>
                                    <option value="Forzado">Forzado</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Rol (opcional)</label>
                                <select class="form-select" id="rolLogin">
                                    <option value="">Todos los roles</option>
                                    <option value="Secretaria">Secretaria</option>
                                    <option value="Medico">Médico</option>
                                    <option value="Paciente">Paciente</option>
                                </select>
                            </div>
                            <button type="button" onclick="descargarAuditoriaLoginsPDF()" class="btn btn-danger w-100 mb-2">
                                <i class="fas fa-file-pdf me-2"></i>
                                Descargar PDF
                            </button>
                            <button type="button" onclick="previsualizarAuditoriaLoginsPDF()" class="btn btn-outline-danger w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa PDF
                            </button>
                            <button type="button" onclick="descargarAuditoriaLoginsExcel()" class="btn btn-success w-100">
                                <i class="fas fa-file-excel me-2"></i>
                                Descargar Excel
                            </button>
                        </form>
                    </div>
                </div>
            </div>


            <!-- TRAZABILIDAD TURNOS REPORT -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 border-start border-warning border-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-history me-2 text-warning"></i>
                            Trazabilidad de Turnos
                        </h5>
                        <p class="text-muted">Historial completo de acciones realizadas sobre los turnos</p>
                        <form id="formTrazabilidadTurnos" class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Desde</label>
                                <input type="date" id="fechaDesdeTrazabilidad" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fecha Hasta</label>
                                <input type="date" id="fechaHastaTrazabilidad" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Usuario (opcional)</label>
                                <select class="form-select" id="usuarioTrazabilidad">
                                    <option value="">Todos los usuarios</option>
                                    @foreach (var usuario in ViewBag.usuarios)
                                    {
                                        <option value="@usuario.Nombre">@usuario.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Acción (opcional)</label>
                                <select class="form-select" id="accionTrazabilidad">
                                    <option value="">Todas las acciones</option>
                                    <option value="INSERT">INSERT – Reserva</option>
                                    <option value="UPDATE">UPDATE – Modificación</option>
                                    <option value="CANCEL">CANCEL – Cancelación</option>
                                    <option value="FINALIZE">FINALIZE – Finalización</option>
                                    <option value="NOSHOW">NOSHOW – Inasistencia</option>
                                </select>
                            </div>
                            <button type="button" onclick="descargarTrazabilidadTurnosPDF()" class="btn btn-danger w-100 mb-2">
                                <i class="fas fa-file-pdf me-2"></i>
                                Descargar PDF
                            </button>
                            <button type="button" onclick="previsualizarTrazabilidadTurnosPDF()" class="btn btn-outline-danger w-100 mb-2">
                                <i class="fas fa-eye me-2"></i>
                                Vista Previa PDF
                            </button>
                            <button type="button" onclick="descargarTrazabilidadTurnosExcel()" class="btn btn-success w-100">
                                <i class="fas fa-file-excel me-2"></i>
                                Descargar Excel
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- DASHBOARD INTERACTIVO (New - Chart.js) -->
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 border-start border-3" style="border-color: #764ba2 !important;">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-tachometer-alt me-2" style="color: #764ba2;"></i>
                            Dashboard Interactivo
                        </h5>
                        <p class="text-muted">
                            <strong>📊 Gráficos interactivos en el navegador</strong><br>
                            Visualizá las estadísticas con gráficos animados de Chart.js directamente en el sistema, sin descargar archivos.
                        </p>
                        <ul class="small text-muted mb-3">
                            <li>Gráfico de torta con distribución por estado</li>
                            <li>Barras con turnos por especialidad</li>
                            <li>Área polar por día de la semana</li>
                            <li>Efectividad por médico con colores por rendimiento</li>
                            <li>Distribución por obra social y horarios</li>
                            <li>Insights y alertas automáticas</li>
                        </ul>
                        <form id="formDashboard" class="mt-3">
                            <div class="mb-3">
                                <label class="form-label">Fecha Desde</label>
                                <input type="date" id="fechaDesdeDashboard" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fecha Hasta</label>
                                <input type="date" id="fechaHastaDashboard" class="form-control" required />
                            </div>
                            <button type="button" onclick="abrirDashboard()" class="btn w-100 mb-2 text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="fas fa-chart-line me-2"></i>
                                Ver Dashboard Interactivo
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .stat-card {
        display: flex;
        align-items: center;
        padding: 1.5rem;
        background-color: #f8f9fa;
        border-radius: 12px;
        transition: all 0.3s;
    }
    
    .stat-card:hover {
        background-color: #e9ecef;
        transform: translateY(-2px);
    }
    
    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        margin-right: 1rem;
    }
    
    .stat-content {
        flex: 1;
    }
    
    .stat-number {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 0.25rem;
        color: #2d3748;
    }
    
    .stat-label {
        color: #6c757d;
        margin-bottom: 0;
        font-size: 0.9rem;
    }
    
    .form-control, .form-select {
        background-color: #ffffff !important;
        color: #000000 !important;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.25);
    }
</style>

<script>
    function showClientError(message){

        const errorDiv = document.getElementById('clientErrorMessage');
        const errorText = document.getElementById('clientErrorText');
        errorText.textContent = message;
        errorDiv.style.display = 'block';
        
        // Scroll to top to show error
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function clearClientError() {
        document.getElementById('clientErrorMessage').style.display = 'none';
    }
    function validarFechas(fechaDesde, fechaHasta){
        clearClientError();
        if (!fechaDesde || !fechaHasta) {
            showClientError('Por favor seleccione ambas fechas');
            return false;
        }
        if (fechaDesde > fechaHasta) {
            showClientError('La fecha de inicio no puede ser después de la fecha de fin');
            return false;
        }
        
        const hoy = new Date().toISOString().split('T')[0];
        if (fechaDesde > hoy || fechaHasta > hoy) {
            showClientError('No se pueden seleccionar fechas futuras');
            return false;
        }
        
        return true;
    }
    function filtrarAccionPorUsuario(){
        const usuarioSelect = document.getElementById('usuarioAcciones');
        const accionSelect = document.getElementById('accionAudit');
        const selectedOption = usuarioSelect.options[usuarioSelect.selectedIndex];
        
        // Get actions for selected user from data attribute
        const accionesPermitidas = selectedOption.getAttribute('data-acciones');
        
        // Clear current options
        accionSelect.innerHTML = '<option value="">Todas las acciones</option>';
        
        if (!accionesPermitidas || accionesPermitidas === "") {
            // If "Todos los Usuarios" selected, show all actions
            accionSelect.innerHTML += '<option value="INSERT">INSERT</option>';
