    // Handler for when period is selected - loads médicos based on period and current specialty selection
    async function onPeriodoChange() {
        const periodo = document.getElementById('periodo').value;
        const medicoSelect = document.getElementById('medicoId');
        
        // Reset medico dropdown
        medicoSelect.innerHTML = '<option value="">Todos los médicos</option>';
        
        if (!periodo || periodo === "") {
            // Disable medico dropdown if no period selected
            medicoSelect.disabled = true;
            return;
        }
        
        // Enable medico dropdown and load doctors
        medicoSelect.disabled = false;
        await cargarMedicosPorEspecialidadYPeriodo();
    }

    // Filter doctors by specialty (also considers the period)
    async function filtrarMedicosPorEspecialidad() {
        const periodo = document.getElementById('periodo').value;
        
        // Only reload if period is selected
        if (!periodo || periodo === "") {
            return;
        }
        
        await cargarMedicosPorEspecialidadYPeriodo();
    }

    // Helper function to load doctors based on specialty and period
    async function cargarMedicosPorEspecialidadYPeriodo() {
        const periodo = document.getElementById('periodo').value;
        const especialidadId = document.getElementById('especialidadId').value;
        const medicoSelect = document.getElementById('medicoId');
        
        // Clear current options
        medicoSelect.innerHTML = '<option value="">Todos los médicos</option>';
        
        const mesesAtras = parseInt(periodo);
        
        try {
            let url = `/Reportes/GetMedicosPorEspecialidadYPeriodo?mesesAtras=${mesesAtras}`;
            if (especialidadId && especialidadId !== "") {
                url += `&especialidadId=${especialidadId}`;
            }
            
            const response = await fetch(url);
            const medicos = await response.json();
            
            medicos.forEach(medico => {
                const option = document.createElement('option');
                option.value = medico.id;
                option.textContent = medico.nombre;
                medicoSelect.appendChild(option);
            });
        } catch (error) {
            console.error('Error al cargar médicos:', error);
            showClientError('Error al cargar los médicos. Por favor intente nuevamente.');
        }
    }

