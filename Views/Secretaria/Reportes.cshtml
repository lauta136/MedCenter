            accionSelect.innerHTML += '<option value="CANCEL">CANCEL</option>';
            accionSelect.innerHTML += '<option value="FINALIZE">FINALIZE</option>';
            accionSelect.innerHTML += '<option value="NOSHOW">NOSHOW</option>';
        } else {
            // Show only actions this user can perform
            const acciones = accionesPermitidas.split(',');
            acciones.forEach(accion => {
