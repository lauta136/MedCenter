@section Scripts {
    <script>
        let currentUserId = null;
        let allUsers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllUsers));
        let allPermissions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllPermissions));
        
        // Helper function to safely get action string in lowercase
        function getActionString(accion) {
            if (typeof accion === 'string') {
                return accion.toLowerCase();
            }
            // If it's a number (enum value), convert to lowercase string
            return String(accion).toLowerCase();
        }

        // Initialize event listeners on DOM load
        document.addEventListener('DOMContentLoaded', function() {
            // Load manual groups on page load
            loadManualGroups();

            // Fix for modal backdrop issue - ensure all backdrops are removed when modals are hidden
            document.querySelectorAll('.modal').forEach(modalEl => {
                modalEl.addEventListener('hidden.bs.modal', function () {
                    // Remove any lingering backdrops
                    document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
                    // Restore body scroll
                    document.body.classList.remove('modal-open');
                    document.body.style.overflow = '';
                    document.body.style.paddingRight = '';
                });
            });

            // Event delegation for all buttons with data-action attribute
            document.addEventListener('click', function(e) {
                const target = e.target.closest('[data-action]');
                if (!target) return;

                const action = target.dataset.action;
                
                console.log('Action clicked:', action); // Debug log
                
                switch(action) {
                    case 'view-permissions':
                        viewUserPermissions(parseInt(target.dataset.userId), target.dataset.userName);
                        break;
                    case 'manage-permissions':
                        manageUserPermissions(parseInt(target.dataset.userId), target.dataset.userName);
                        break;
                    case 'create-group':
                        e.preventDefault();
                        e.stopPropagation();
                        console.log('Create group action triggered');
                        showCreateGroupModal();
                        break;
                    case 'manage-manual-group':
                        manageManualGroup(parseInt(target.dataset.groupId), target.dataset.groupName);
                        break;
                    case 'delete-manual-group':
                        deleteManualGroup(parseInt(target.dataset.groupId), target.dataset.groupName);
                        break;
                    case 'copy-permissions':
                        showCopyPermissionsModal();
                        break;
                    case 'assign-role':
                        showAssignRoleModal();
                        break;
                    case 'remove-all-permissions':
                        showRemoveAllPermissionsModal();
                        break;
                    case 'assign-permission':
                        assignPermission(parseInt(target.dataset.userId), parseInt(target.dataset.permissionId));
                        break;
                    case 'remove-permission':
                        removePermission(parseInt(target.dataset.userId), parseInt(target.dataset.permissionId));
                        break;
                    case 'activate-account':
                        activateAccount(parseInt(target.dataset.userId), target.dataset.userName, target.dataset.userRole);
                        break;
                    case 'deactivate-account':
                        deactivateAccount(parseInt(target.dataset.userId), target.dataset.userName, target.dataset.userRole);
                        break;
                }
            });

            // Status filter functionality
            document.querySelectorAll('input[name="statusFilter"]').forEach(radio => {
                radio.addEventListener('change', function() {
                    filterUsersByStatus(this.value);
                });
            });

            // Initialize tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });

        // User search functionality
        document.getElementById('userSearch')?.addEventListener('input', function(e) {
            applyUserFilters();
        });

        // Filter users by search term and status
        function applyUserFilters() {
            const searchTerm = document.getElementById('userSearch')?.value.toLowerCase() || '';
            const statusFilter = document.querySelector('input[name="statusFilter"]:checked')?.value || 'all';
            
            document.querySelectorAll('.user-card').forEach(card => {
                const userName = card.dataset.userName.toLowerCase();
                const userEmail = card.dataset.userEmail.toLowerCase();
                const isActive = card.dataset.userActive === 'true';
                
                const matchesSearch = userName.includes(searchTerm) || userEmail.includes(searchTerm);
                const matchesStatus = statusFilter === 'all' || 
                                    (statusFilter === 'active' && isActive) || 
                                    (statusFilter === 'inactive' && !isActive);
                
                if (matchesSearch && matchesStatus) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Filter users by status
        function filterUsersByStatus(status) {
            applyUserFilters();
        }

        // Permission search functionality
        document.getElementById('permissionSearch')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            document.querySelectorAll('#permissionsTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        // View user permissions
        function viewUserPermissions(userId, userName) {
            const user = allUsers.find(u => u.UserId === userId);
            if (!user) return;

            document.getElementById('userPermissionsModalTitle').textContent = `Permisos de ${userName}`;
            
            let html = '<div class="mb-3">';
            html += `<h6>Roles:</h6>`;
            if (user.Roles && user.Roles.length > 0) {
                user.Roles.forEach(role => {
                    html += `<span class="role-badge role-badge-${role.toLowerCase()}">${role}</span>`;
                });
            } else {
                html += '<p class="text-muted">Sin roles asignados</p>';
            }
            html += '</div>';

            html += '<div>';
            html += `<h6>Permisos (${user.Permissions.length}):</h6>`;
            if (user.Permissions.length > 0) {
                user.Permissions.forEach(perm => {
                    html += `<span class="permission-badge permission-badge-${getActionString(perm.Accion)}" 
                             data-bs-toggle="tooltip" title="${perm.Descripcion}">
                             ${perm.Nombre} <small>(${perm.Recurso} - ${perm.Accion})</small>
                             </span>`;
                });
            } else {
                html += '<p class="text-muted">Sin permisos asignados</p>';
            }
            html += '</div>';

            document.getElementById('userPermissionsModalBody').innerHTML = html;
            
            // Initialize tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            new bootstrap.Modal(document.getElementById('userPermissionsModal')).show();
        }

        // Manage user permissions
        function manageUserPermissions(userId, userName) {
            currentUserId = userId;
            const user = allUsers.find(u => u.UserId === userId);
            if (!user) return;

            document.getElementById('managePermissionsModalTitle').textContent = `Gestionar Permisos - ${userName}`;

            const userPermissionIds = user.Permissions.map(p => p.Id);
            
            // Available permissions
            let availableHtml = '';
            allPermissions.filter(p => !userPermissionIds.includes(p.Id)).forEach(perm => {
                availableHtml += `
                    <div class="permission-item">
                        <div>
                            <strong>${perm.Nombre}</strong><br>
                            <small class="text-muted">${perm.Descripcion}</small><br>
                        </div>
                        <button class="btn btn-sm btn-success" data-action="assign-permission" data-user-id="${userId}" data-permission-id="${perm.Id}">
                            <i class="fas fa-plus"></i> Asignar
                        </button>
                    </div>
                `;
            });
            document.getElementById('availablePermissions').innerHTML = availableHtml || '<p class="text-muted">No hay permisos disponibles</p>';

            // Assigned permissions
            let assignedHtml = '';
            user.Permissions.forEach(perm => {
                assignedHtml += `
                    <div class="permission-item">
                        <div>
                            <strong>${perm.Nombre}</strong><br>
                            <small class="text-muted">${perm.Descripcion}</small><br>
                            <small><span class="badge bg-secondary">${perm.Recurso}</span> 
                            <span class="badge bg-info">${perm.Accion}</span></small>
                        </div>
                        <button class="btn btn-sm btn-danger" data-action="remove-permission" data-user-id="${userId}" data-permission-id="${perm.Id}">
                            <i class="fas fa-minus"></i> Remover
                        </button>
                    </div>
                `;
            });
