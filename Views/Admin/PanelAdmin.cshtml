                // Setup search functionality
                setupGroupSearch('searchAvailableGroupUsers', 'availableGroupUsers');
                setupGroupSearch('searchAssignedGroupUsers', 'assignedGroupUsers');
                setupGroupSearch('searchAvailableGroupPerms', 'availableGroupPermissions');
                setupGroupSearch('searchAssignedGroupPerms', 'assignedGroupPermissions');

                const modalElement = document.getElementById('manageGroupModal');
                const existingModal = bootstrap.Modal.getInstance(modalElement);
                if (existingModal) {
                    existingModal.dispose();
