@model MedCenter.DTOs.PermissionManagementViewModel
@using MedCenter.Services.TurnoSv
@{
    ViewData["Title"] = "Panel de Administración de Permisos";
    // Use secretaria layout if user has secretaria role, otherwise use admin layout
    var isAdmin = ViewBag.Rol != RolUsuario.Secretaria;
    var primaryColor = isAdmin ? "#dc2626" : "#10b981";
    var primaryColorDark = isAdmin ? "#991b1b" : "#059669";
    Layout = ViewBag.Rol == RolUsuario.Secretaria ? "~/Views/Shared/_SecretariaLayout.cshtml" : "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .permission-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        margin: 0.25rem;
        border-radius: 1rem;
        font-size: 0.85rem;
        font-weight: 500;
    }
    
    .permission-badge-create { background-color: #10b981; color: white; }
    .permission-badge-update { background-color: #3b82f6; color: white; }
    .permission-badge-delete { background-color: #ef4444; color: white; }
    .permission-badge-view { background-color: #8b5cf6; color: white; }
    .permission-badge-manage { background-color: #f59e0b; color: white; }
    .permission-badge-assign { background-color: #06b6d4; color: white; }
    .permission-badge-remove { background-color: #ec4899; color: white; }
    
    .role-badge {
        display: inline-block;
        padding: 0.35rem 0.9rem;
        margin: 0.25rem;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        font-weight: 600;
    }
    
    .role-badge-admin { background-color: #dc2626; color: white; }
    .role-badge-medico { background-color: #2563eb; color: white; }
    .role-badge-secretaria { background-color: #059669; color: white; }
    .role-badge-paciente { background-color: #7c3aed; color: white; }
    
    .group-card {
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        transition: all 0.3s;
    }
    
    .group-card:hover {
        border-color: @primaryColor;
        box-shadow: 0 4px 12px @(isAdmin ? "rgba(220, 38, 38, 0.15)" : "rgba(16, 185, 129, 0.15)");
    }
    
    .user-card {
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
        transition: all 0.2s;
        background-color: white;
    }
    
    .user-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transform: translateY(-2px);
    }
    
    .permission-selector {
        max-height: 400px;
        overflow-y: auto;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 1rem;
    }
    
    .permission-item {
        padding: 0.5rem;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    
    .permission-item:last-child {
        border-bottom: none;
    }
    
    .tab-content {
        padding: 2rem;
        background-color: white;
        border-radius: 0 0.5rem 0.5rem 0.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    
    .nav-tabs .nav-link {
        color: #6b7280;
        font-weight: 500;
        border: none;
        border-bottom: 3px solid transparent;
    }
    
    .nav-tabs .nav-link.active {
        color: @primaryColor;
        border-bottom-color: @primaryColor;
        background-color: transparent;
    }
    
    .search-box {
        position: relative;
    }
    
    .search-box input {
        padding-left: 2.5rem;
        background-color: white !important;
        color: #1f2937 !important;
    }
    
    .search-box i {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
    }
    
    .action-btn {
        padding: 0.25rem 0.75rem;
        font-size: 0.85rem;
        border-radius: 0.375rem;
    }
    
    .user-card h6,
    .user-card small,
    .user-card .text-muted {
        color: #6b7280 !important;
    }
    
    .user-card h6.fw-semibold {
        color: #1f2937 !important;
    }
    
    .permission-item strong,
    .permission-item small {
        color: #1f2937 !important;
    }
    
    .permission-item .text-muted {
        color: #6b7280 !important;
    }
    
    .modal-header .modal-title {
        color: #1f2937 !important;
    }
    
    .modal-body h6 {
        color: #1f2937 !important;
    }
    
    .card-body h5,
    .card-body h6,
    .card-body strong,
    .card-body .fw-semibold {
        color: #1f2937 !important;
    }
    
    
    .tab-content h5,
    .tab-content h6 {
        color: #1f2937 !important;
    }
    
    .group-card strong,
    .group-card .fw-semibold {
        color: #1f2937 !important;
    }
    
    .card-header[style*="gradient"] h5,
    .card-header[style*="gradient"] .fw-semibold {
        color: white !important;
    }
    
    #searchAvailableGroupPerms,
    #searchAssignedGroupPerms {
        background-color: white !important;
        color: #1f2937 !important;
        border-color: #d1d5db !important;
    }
    
    #searchAvailableGroupPerms::placeholder,
    #searchAssignedGroupPerms::placeholder {
        color: #9ca3af !important;
    }

    /* ── Modal form controls: override site.css dark-theme ─────────────────── */
    .modal-content {
        background-color: #ffffff !important;
        color: #1f2937 !important;
    }

    .modal-content .form-control {
        background-color: #f9fafb !important;
        color: #1f2937 !important;
        border-color: #d1d5db !important;
    }

    .modal-content .form-control:focus {
        background-color: #ffffff !important;
        color: #1f2937 !important;
        border-color: @primaryColor !important;
        box-shadow: 0 0 0 2px rgba(0,0,0,0.05), 0 0 0 4px @(primaryColor + "33") !important;
    }

    .modal-content .form-control::placeholder {
        color: #9ca3af !important;
    }

    .modal-content .form-label,
    .modal-content label {
        color: #374151 !important;
    }

    .modal-content .form-text {
        color: #6b7280 !important;
    }

    .modal-content .text-muted {
        color: #6b7280 !important;
    }

    .modal-body {
        color: #1f2937 !important;
    }
</style>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold">
                        <i class="fas fa-shield-alt me-2" style="color: @primaryColor;"></i>
                        Panel de Administración de Permisos
                    </h4>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createAccountModal">
                            <i class="fas fa-user-plus me-2"></i>Crear Cuenta
                        </button>
                        <button class="btn @(isAdmin ? "btn-danger" : "btn-success")" data-bs-toggle="modal" data-bs-target="#quickActionsModal">
                            <i class="fas fa-bolt me-2"></i>Acciones Rápidas
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs Navigation -->
        <ul class="nav nav-tabs mb-0" id="permissionTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab">
                    <i class="fas fa-users me-2"></i>Usuarios
                </button>
            </li>
            @if(ViewBag.CanViewGroups == true)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="groups-tab" data-bs-toggle="tab" data-bs-target="#groups" type="button" role="tab">
                        <i class="fas fa-layer-group me-2"></i>Grupos por Permisos
                    </button>
                </li>
            }
            @if(ViewBag.CanViewRoles == true)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="roles-tab" data-bs-toggle="tab" data-bs-target="#roles" type="button" role="tab">
                        <i class="fas fa-user-tag me-2"></i>Roles
                    </button>
                </li>
            }
            @if(ViewBag.CanViewAllPermissions == true)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="permissions-tab" data-bs-toggle="tab" data-bs-target="#permissions" type="button" role="tab">
                        <i class="fas fa-key me-2"></i>Todos los Permisos
                    </button>
                </li>
            }
        </ul>

        <!-- Tabs Content -->
        <div class="tab-content" id="permissionTabsContent">
            
            <!-- Users Tab -->
            <div class="tab-pane fade show active" id="users" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" class="form-control" id="userSearch" placeholder="Buscar usuario por nombre o email...">
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="btn-group me-3" role="group" aria-label="Filtro de estado">
                            <input type="radio" class="btn-check" name="statusFilter" id="filterAll" value="all" checked autocomplete="off">
                            <label class="btn btn-outline-secondary" for="filterAll">
                                <i class="fas fa-users"></i> Todos
                            </label>

                            <input type="radio" class="btn-check" name="statusFilter" id="filterActive" value="active" autocomplete="off">
                            <label class="btn btn-outline-success" for="filterActive">
                                <i class="fas fa-check-circle"></i> Activos
                            </label>

                            <input type="radio" class="btn-check" name="statusFilter" id="filterInactive" value="inactive" autocomplete="off">
                            <label class="btn btn-outline-danger" for="filterInactive">
                                <i class="fas fa-ban"></i> Inactivos
                            </label>
                        </div>
                        <span class="text-muted">Total de usuarios: <strong>@Model.AllUsers.Count</strong></span>
                    </div>
                </div>

                <div id="usersList">
                    @foreach (var user in Model.AllUsers)
                    {
                        <div class="user-card" data-user-id="@user.UserId" data-user-name="@user.UserName" data-user-email="@user.Email" data-user-active="@user.IsActive.ToString().ToLower()" data-user-role="@user.Role.ToString()">
                            <div class="row align-items-center">
                                <div class="col-md-4">
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar text-white rounded-circle me-3" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem; background-color: @primaryColor;">
                                            @user.UserName?.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-semibold">@user.UserName</h6>
                                            <small class="text-muted">@user.Email</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-2">          
                                        <span class="role-badge role-badge-@user.Role.ToString().ToLower()">@user.Role</span>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success ms-2">
                                                <i class="fas fa-check-circle"></i> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger ms-2">
                                                <i class="fas fa-ban"></i> Inactivo
                                            </span>
                                        }
                                    </div>
                                    <small class="text-muted">
                                        <i class="fas fa-key me-1"></i>
                                        @user.Permissions.Count permiso(s)
                                    </small>
                                </div>
                                <div class="col-md-4 text-end">
                                    <button class="btn btn-sm btn-outline-primary action-btn me-1" data-action="view-permissions" data-user-id="@user.UserId" data-user-name="@user.UserName">
                                        <i class="fas fa-eye"></i> Ver
                                    </button>
                                    <button class="btn btn-sm @(isAdmin ? "btn-outline-danger" : "btn-outline-success") action-btn me-1" data-action="manage-permissions" data-user-id="@user.UserId" data-user-name="@user.UserName">
                                        <i class="fas fa-edit"></i> Gestionar
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary action-btn me-1" onclick="openEditAccountModal(@user.UserId, '@user.UserName', '@user.Role.ToString()')">
                                        <i class="fas fa-user-edit"></i> Editar
                                    </button>
                                    @if (user.IsActive)
                                    {
                                        <button class="btn btn-sm btn-outline-danger action-btn" data-action="deactivate-account" data-user-id="@user.UserId" data-user-name="@user.UserName" data-user-role="@user.Role.ToString()">
                                            <i class="fas fa-user-times"></i> Desactivar
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success action-btn" data-action="activate-account" data-user-id="@user.UserId" data-user-name="@user.UserName" data-user-role="@user.Role.ToString()">
                                            <i class="fas fa-user-check"></i> Activar
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Groups Tab -->
            <div class="tab-pane fade" id="groups" role="tabpanel">
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <p class="text-muted mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        Gestiona grupos de permisos manuales y automáticos.
                    </p>
                    <button class="btn btn-sm" 
                            style="background-color: @primaryColor; color: white;" 
                            data-action="create-group" 
                            data-bs-toggle="modal" 
                            data-bs-target="#createGroupModal"
                            type="button"
                            onclick="showCreateGroupModal(); return false;">
                        <i class="fas fa-plus me-2"></i>Crear Grupo Manual
                    </button>
                </div>

                <!-- Manual Groups Section -->
                <div class="mb-5">
                    <h5 class="fw-semibold mb-3">
                        <i class="fas fa-users-cog me-2" style="color: @primaryColor;"></i>
                        Grupos Manuales
                    </h5>
                    <div id="manualGroupsList">
                        <p class="text-muted text-center py-4">
                            <i class="fas fa-folder-open fa-2x mb-2 d-block"></i>
                            No hay grupos manuales creados. Haz clic en "Crear Grupo Manual" para comenzar.
                        </p>
                    </div>
                </div>

                <!-- Auto-grouped Users Section -->
                <div class="mb-4">
                    <h5 class="fw-semibold mb-3">
                        <i class="fas fa-layer-group me-2" style="color: @primaryColor;"></i>
                        Usuarios Agrupados por Conjunto de Permisos
                    </h5>
                    <p class="text-muted">Los usuarios están agrupados según tengan el mismo conjunto de permisos. Esto facilita la gestión masiva de permisos.</p>
                </div>

                @if (Model.PermissionGroups.Any())
                {
                    @foreach (var group in Model.PermissionGroups)
                    {
                        <div class="card group-card mb-4">
                            <div class="card-header bg-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-semibold">
                                            <i class="fas fa-users me-2" style="color: @primaryColor;"></i>
                                            Grupo de @group.Users.Count usuario(s)
                                        </h6>
                                        <small class="text-muted">@group.Permissions.Count permiso(s) en común</small>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h6 class="fw-semibold mb-3">Usuarios en este grupo:</h6>
                                        @foreach (var user in group.Users)
                                        {
                                            <div class="d-flex align-items-center mb-2">
                                                <div class="user-avatar text-white rounded-circle me-2" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: bold; background-color: @primaryColor;">
                                                    @user.UserName?.Substring(0, 1).ToUpper()
                                                </div>
                                                <div>
                                                    <strong>@user.UserName</strong>
                                                    <br><small class="text-muted">@user.Email</small>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="col-md-6">
                                        <h6 class="fw-semibold mb-3">Permisos compartidos:</h6>
                                        <div style="max-height: 200px; overflow-y: auto;">
                                            @foreach (var permission in group.Permissions)
                                            {
                                                <span class="permission-badge permission-badge-@permission.Accion.ToString().ToLower()">
                                                    @permission.Nombre
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    }
                    else
                    {
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        No hay grupos de usuarios con permisos compartidos.
                    </div>
                }
            </div>

            <!-- Roles Tab -->
            <div class="tab-pane fade" id="roles" role="tabpanel">
                <div class="mb-4">
                    <h5 class="fw-semibold mb-3">
                        <i class="fas fa-user-tag me-2" style="color: @primaryColor;"></i>
                        Permisos por Rol
                    </h5>
                    <p class="text-muted">Visualiza los permisos asociados a cada rol del sistema.</p>
                </div>

                @foreach (var rolePermission in Model.RolePermissions)
                {
                    <div class="card mb-4">
                        <div class="card-header" style="background: linear-gradient(135deg, @primaryColor 0%, @primaryColorDark 100%); color: white;">
                            <h5 class="mb-0 fw-semibold">
                                <i class="fas fa-shield-alt me-2"></i>
                                Rol: @rolePermission.Key
                            </h5>
                        </div>
                        <div class="card-body">
                            @if (rolePermission.Value.Any())
                            {
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <span class="text-muted">Total de permisos: <strong>@rolePermission.Value.Count</strong></span>
                                    </div>
                                    <div class="col-12">
                                        @foreach (var permission in rolePermission.Value)
                                        {
                                            <span class="permission-badge permission-badge-@permission.Accion.ToString().ToLower()" 
                                                  data-bs-toggle="tooltip" 
                                                  title="@permission.Descripcion">
                                                <i class="fas fa-key me-1"></i>
                                                @permission.Nombre
                                                <small>(@permission.Recurso - @permission.Accion)</small>
                                            </span>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">
                                    <i class="fas fa-exclamation-circle me-2"></i>
                                    Este rol no tiene permisos asignados.
                                </p>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- All Permissions Tab -->
            <div class="tab-pane fade" id="permissions" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" class="form-control" id="permissionSearch" placeholder="Buscar permiso...">
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <span class="text-muted">Total de permisos: <strong>@Model.AllPermissions.Count</strong></span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover" id="permissionsTable">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th>Recurso</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var permission in Model.AllPermissions.OrderBy(p => p.Recurso).ThenBy(p => p.Accion))
                            {
                                <tr>
                                    <td><strong>@permission.Id</strong></td>
                                    <td>
                                        <span class="permission-badge permission-badge-@permission.Accion.ToString().ToLower()">
                                            @permission.Nombre
                                        </span>
                                    </td>
                                    <td>@permission.Descripcion</td>
                                    <td><span class="badge bg-secondary">@permission.Recurso</span></td>
                                    <td><span class="badge bg-info">@permission.Accion</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Account Modal -->
<div class="modal fade" id="createAccountModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color: @primaryColor;">
                <h5 class="modal-title">
                    <i class="fas fa-user-plus me-2"></i>Crear Nueva Cuenta
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Common fields -->
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nombre completo *</label>
                        <input type="text" id="ca_nombre" class="form-control" placeholder="Nombre completo">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email *</label>
                        <input type="email" id="ca_email" class="form-control" placeholder="correo@@ejemplo.com">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Contraseña *</label>
                        <input type="password" id="ca_password" class="form-control" placeholder="Mínimo 6 caracteres">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Confirmar contraseña *</label>
                        <input type="password" id="ca_confirmPassword" class="form-control" placeholder="Repetir contraseña">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Rol *</label>
                        <select id="ca_role" class="form-select" onchange="caToggleRoleFields()">
                            <option value="">-- Seleccionar rol --</option>
                            <option value="Paciente">Paciente</option>
                            <option value="Medico">Médico</option>
                            <option value="Secretaria">Secretaria</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                </div>

                <!-- Paciente fields -->
                <div id="ca_pacienteFields" class="role-fields mt-3" style="display:none;">
                    <hr>
                    <h6 class="fw-semibold mb-3"><i class="fas fa-id-card me-2"></i>Datos del Paciente</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">DNI *</label>
                            <input type="text" id="ca_dni" class="form-control" placeholder="Número de DNI">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Teléfono *</label>
                            <input type="text" id="ca_telefono" class="form-control" placeholder="Número de teléfono">
                        </div>
                    </div>
                </div>

                <!-- Médico fields -->
