        // Remove selected permissions from group
        async function removeSelectedPermissionsFromGroup() {
            const selectedPermissions = Array.from(document.querySelectorAll('.assigned-permission-checkbox:checked'))
                .map(cb => parseInt(cb.value));

            if (selectedPermissions.length === 0) {
                showNotification('error', 'Selecciona al menos un permiso');
                return;
            }

            if (!confirm(`¿Está seguro de remover ${selectedPermissions.length} permiso(s) del grupo?`)) {
                return;
            }

            try {
                const response = await fetch(`/Admin/RemovePermissionsFromGroup/${currentManualGroupId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(selectedPermissions)
                });

                if (!response.ok) {
                    const errorText = await response.text();
