            if (selectedPermissions.length === 0) {
                showNotification('error', 'Selecciona al menos un permiso');
                return;
            }

            try {
                const response = await fetch(`/Admin/AddPermissionsToGroup/${currentManualGroupId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(selectedPermissions)
                });

                if (!response.ok) {
