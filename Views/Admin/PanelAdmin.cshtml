        // Update selected count
        function updateSelectedCount() {
            const selectedUsers = document.querySelectorAll('.group-user-checkbox:checked').length;
            const selectedPermissions = document.querySelectorAll('.group-permission-checkbox:checked').length;
            
            document.getElementById('selectedUsersCount').textContent = selectedUsers;
