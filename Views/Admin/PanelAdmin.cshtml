        // Helper function to setup search functionality
        function setupGroupSearch(searchInputId, containerId) {
            const searchInput = document.getElementById(searchInputId);
            if (searchInput) {
                // Clone to remove existing listeners
                const newSearchInput = searchInput.cloneNode(true);
                searchInput.parentNode.replaceChild(newSearchInput, searchInput);
                
                document.getElementById(searchInputId).addEventListener('input', function(e) {
                    const searchTerm = e.target.value.toLowerCase();
                    document.querySelectorAll(`#${containerId} .permission-item`).forEach(item => {
                        const text = item.dataset.searchText;
                        item.style.display = text && text.includes(searchTerm) ? '' : 'none';
                    });
                });
            }
        }

        // Add selected users to group
        async function addSelectedUsersToGroup() {
            const selectedUsers = Array.from(document.querySelectorAll('.available-user-checkbox:checked'))
                .map(cb => parseInt(cb.value));

            if (selectedUsers.length === 0) {
                showNotification('error', 'Selecciona al menos un usuario');
                return;
            }

            try {
                const response = await fetch(`/Admin/AddUsersToGroup/${currentManualGroupId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(selectedUsers)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    let errorMessage = 'Error al agregar usuarios';
                    try {
                        const errorJson = JSON.parse(errorText);
                        errorMessage = errorJson.message || errorMessage;
                    } catch (e) {
                        console.error('Could not parse error response:', errorText);
                    }
                    showNotification('error', errorMessage);
                    return;
                }

                const result = await response.json();
                
                if (result.success) {
                    showNotification('success', `${selectedUsers.length} usuario(s) agregado(s) exitosamente`);
                    const modalInstance = bootstrap.Modal.getInstance(document.getElementById('manageGroupModal'));
                    if (modalInstance) {
                        modalInstance.hide();
                    }
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification('error', result.message || 'Error al agregar usuarios');
                }
            } catch (error) {
                showNotification('error', 'Error de red al agregar usuarios: ' + error.message);
                console.error('Error:', error);
            }
        }

        // Remove selected users from group
        async function removeSelectedUsersFromGroup() {
            const selectedUsers = Array.from(document.querySelectorAll('.assigned-user-checkbox:checked'))
                .map(cb => parseInt(cb.value));

            if (selectedUsers.length === 0) {
                showNotification('error', 'Selecciona al menos un usuario');
                return;
            }

            if (!confirm(`¿Está seguro de remover ${selectedUsers.length} usuario(s) del grupo?`)) {
                return;
            }

            try {
                const response = await fetch(`/Admin/RemoveUsersFromGroup/${currentManualGroupId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(selectedUsers)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    let errorMessage = 'Error al remover usuarios';
                    try {
                        const errorJson = JSON.parse(errorText);
                        errorMessage = errorJson.message || errorMessage;
                    } catch (e) {
                        console.error('Could not parse error response:', errorText);
                    }
                    showNotification('error', errorMessage);
                    return;
                }

                const result = await response.json();
                
                if (result.success) {
                    showNotification('success', `${selectedUsers.length} usuario(s) removido(s) exitosamente`);
                    const modalInstance = bootstrap.Modal.getInstance(document.getElementById('manageGroupModal'));
                    if (modalInstance) {
                        modalInstance.hide();
                    }
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification('error', result.message || 'Error al remover usuarios');
                }
            } catch (error) {
                showNotification('error', 'Error de red al remover usuarios: ' + error.message);
                console.error('Error:', error);
            }
        }

        // Add selected permissions to group
        async function addSelectedPermissionsToGroup() {
            const selectedPermissions = Array.from(document.querySelectorAll('.available-permission-checkbox:checked'))
