        // Create group
        async function createGroup() {
            const name = document.getElementById('groupName').value.trim();
            const description = document.getElementById('groupDescription').value.trim();
            
            if (!name) {
                showNotification('error', 'El nombre del grupo es requerido');
                return;
            }

            const selectedUsers = Array.from(document.querySelectorAll('.group-user-checkbox:checked'))
                .map(cb => parseInt(cb.value));
            const selectedPermissions = Array.from(document.querySelectorAll('.group-permission-checkbox:checked'))
                .map(cb => parseInt(cb.value));

            if (selectedUsers.length === 0) {
                showNotification('error', 'Debes seleccionar al menos un usuario');
                return;
            }

            if (selectedPermissions.length === 0) {
                showNotification('error', 'Debes seleccionar al menos un permiso');
                return;
            }

            try {
                const response = await fetch('/Admin/CreateGroup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userIds: selectedUsers,
                        permissionIds: selectedPermissions,
                        name: name,
                        description: description
                    })
                });

                const result = await response.json();
                
                if (result.success) {
                    showNotification('success', result.message);
                    bootstrap.Modal.getInstance(document.getElementById('createGroupModal')).hide();
                    loadManualGroups();
                } else {
                    showNotification('error', result.message);
                }
            } catch (error) {
                showNotification('error', 'Error al crear el grupo');
                console.error('Error:', error);
            }
        }

        // Delete manual group
        async function deleteManualGroup(groupId, groupName) {
            if (!confirm(`¿Está seguro de eliminar el grupo "${groupName}"? Esta acción no se puede deshacer.`)) {
                return;
            }

            try {
                const response = await fetch(`/Admin/EraseGroup/${groupId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const result = await response.json();
                
                if (result.success) {
                    showNotification('success', result.message);
                    loadManualGroups();
                } else {
                    showNotification('error', result.message);
                }
            } catch (error) {
                showNotification('error', 'Error al eliminar el grupo');
                console.error('Error:', error);
            }
        }

        // Manage manual group (reuses existing modal)
        let currentManualGroupId = null;
        
        async function manageManualGroup(groupId, groupName) {
            currentManualGroupId = groupId;
            
            try {
                const response = await fetch(`/Admin/GetGroupDetails/${groupId}`);
                
                // Check if response is OK before parsing JSON
                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Server response:', response.status, errorText);
                    showNotification('error', `Error del servidor: ${response.status}. El endpoint GetGroupDetails puede no estar implementado.`);
                    return;
                }
                
                const group = await response.json();
                
                if (!group) {
                    showNotification('error', 'No se pudo cargar el grupo');
                    return;
                }

                // Set modal title - with null check
                const modalTitle = document.getElementById('manageGroupModalTitle');
                if (modalTitle) {
                    modalTitle.textContent = `Gestionar Grupo - ${groupName}`;
                }
                
                const userCountElement = document.getElementById('groupUserCount');
                if (userCountElement) {
                    userCountElement.textContent = group.users?.length || 0;
                }

                const groupUserIds = (group.users || []).map(u => u.userId);
                const groupPermissionIds = (group.permissions || []).map(p => p.id);

                // Available users (not in group)
                let availableUsersHtml = '';
                allUsers.filter(u => !groupUserIds.includes(u.UserId)).forEach(user => {
                    availableUsersHtml += `
                        <div class="permission-item" data-search-text="${user.UserName.toLowerCase()} ${user.Email.toLowerCase()}">
                            <div class="form-check">
                                <input class="form-check-input available-user-checkbox" 
                                       type="checkbox" 
                                       value="${user.UserId}" 
                                       id="availableUser${user.UserId}">
                                <label class="form-check-label" for="availableUser${user.UserId}">
                                    <strong>${user.UserName}</strong>
                                    <small class="text-muted d-block">${user.Email}</small>
                                </label>
                            </div>
                        </div>
                    `;
                });
                
                const availableUsersContainer = document.getElementById('availableGroupUsers');
                if (availableUsersContainer) {
                    availableUsersContainer.innerHTML = availableUsersHtml || '<p class="text-muted">Todos los usuarios están en el grupo</p>';
                }

                // Assigned users (in group)
                let assignedUsersHtml = '';
                (group.users || []).forEach(user => {
                    assignedUsersHtml += `
                        <div class="permission-item" data-search-text="${user.userName.toLowerCase()} ${user.email.toLowerCase()}">
                            <div class="form-check">
                                <input class="form-check-input assigned-user-checkbox" 
                                       type="checkbox" 
                                       value="${user.userId}" 
                                       id="assignedUser${user.userId}">
                                <label class="form-check-label" for="assignedUser${user.userId}">
                                    <strong>${user.userName}</strong>
                                    <small class="text-muted d-block">${user.email}</small>
                                </label>
                            </div>
                        </div>
                    `;
                });
                
                const assignedUsersContainer = document.getElementById('assignedGroupUsers');
                if (assignedUsersContainer) {
                    assignedUsersContainer.innerHTML = assignedUsersHtml || '<p class="text-muted">No hay usuarios en este grupo</p>';
                }

                // Available permissions (not in group)
                let availablePermsHtml = '';
                allPermissions.filter(p => !groupPermissionIds.includes(p.Id)).forEach(perm => {
                    const nombre = perm.Nombre || perm.nombre || '';
                    const descripcion = perm.Descripcion || perm.descripcion || '';
                    const accion = perm.Accion || perm.accion || '';
                    const id = perm.Id || perm.id || 0;
                    const badgeClass = `permission-badge-${getActionString(accion)}`;
                    
                    availablePermsHtml += `
                        <div class="permission-item" data-search-text="${nombre.toLowerCase()} ${descripcion.toLowerCase()}">
                            <div class="form-check">
                                <input class="form-check-input available-permission-checkbox" 
                                       type="checkbox" 
                                       value="${id}" 
                                       id="availablePerm${id}">
                                <label class="form-check-label" for="availablePerm${id}">
                                    <strong>${nombre}</strong>
                                    <span class="permission-badge ${badgeClass} ms-2">${accion}</span>
                                    <small class="text-muted d-block">${descripcion}</small>
                                </label>
                            </div>
                        </div>
                    `;
                });
                
                const availablePermsContainer = document.getElementById('availableGroupPermissions');
                if (availablePermsContainer) {
                    availablePermsContainer.innerHTML = availablePermsHtml || '<p class="text-muted">Todos los permisos están asignados</p>';
                }

                // Assigned permissions
                let assignedPermsHtml = '';
                (group.permissions || []).forEach(perm => {
                    const badgeClass = `permission-badge-${getActionString(perm.accion)}`;
                    assignedPermsHtml += `
                        <div class="permission-item" data-search-text="${perm.nombre.toLowerCase()} ${perm.descripcion.toLowerCase()}">
                            <div class="form-check">
                                <input class="form-check-input assigned-permission-checkbox" 
                                       type="checkbox" 
                                       value="${perm.id}" 
                                       id="assignedPerm${perm.id}">
                                <label class="form-check-label" for="assignedPerm${perm.id}">
                                    <strong>${perm.nombre}</strong>
                                    <span class="permission-badge ${badgeClass} ms-2">${perm.accion}</span>
                                    <small class="text-muted d-block">${perm.descripcion}</small>
                                </label>
                            </div>
                        </div>
